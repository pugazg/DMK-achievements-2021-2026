    "baseline": "node scripts/baseline.mjs",
    "a11y": "node scripts/check_contrast.mjs",
    "remediation-queue": "node scripts/remediation_queue.mjs",
    "coverage-matrix": "node scripts/source_coverage_matrix.mjs",
